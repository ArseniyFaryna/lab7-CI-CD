{
  "datasets": [
    {
      "name": "48002046",
      "displayName": "agg_weather_weekly",
      "queryLines": [
        "SELECT week_start, min_temperature, avg_temperature, max_temperature\r\n",
        "FROM dbr_dev.faryna_gold.agg_weather_weekly\r\n",
        "ORDER BY week_start;"
      ],
      "catalog": "dbr_dev",
      "schema": "faryna_gold"
    },
    {
      "name": "ff4c0e65",
      "displayName": "agg_weather_daily",
      "queryLines": [
        "SELECT \r\n",
        "  load_date,\r\n",
        "  avg_temperature,\r\n",
        "  min_temperature,\r\n",
        "  max_temperature,\r\n",
        "  avg_humidity,\r\n",
        "  total_rain,\r\n",
        "  total_snowfall,\r\n",
        "  avg_wind_speed,\r\n",
        "  CASE \r\n",
        "    WHEN total_rain > 0 THEN 'Rainy'\r\n",
        "    WHEN avg_humidity > 80 THEN 'Humid'\r\n",
        "    ELSE 'Normal'\r\n",
        "  END AS weather_type\r\n",
        "FROM dbr_dev.faryna_gold.agg_weather_daily\r\n",
        "ORDER BY load_date"
      ],
      "catalog": "dbr_dev",
      "schema": "faryna_gold"
    }
  ],
